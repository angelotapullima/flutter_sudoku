{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sudoku (Local)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define-from-file=env/local.json"
      ]
    },
    {
      "name": "Sudoku (Dev)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define-from-file=env/dev.json"
      ]
    },
    {
      "name": "Sudoku (Prod)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define-from-file=env/prod.json"
      ]
    },
    {
      "name": "Sudoku Web (Chrome - Dev Nube)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-port",
        "8080"
      ]
    },
    {
      "name": "Sudoku Web (Chrome - Local API)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-port",
        "8080",
        "--dart-define=BASE_URL=http://localhost:3000/api"
      ]
    }
  ]
}
